# Module 4.1 — Service Layer Swap toggle
# true  = always use bundled mock JSON (Module 2 behavior, safe default)
# false = call the real FastAPI backend, with automatic mock fallback on error
VITE_USE_MOCK_API=true

# Only used when VITE_USE_MOCK_API=false
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/api/ws/live

# After deploying (Module 4.4), set these in Vercel's dashboard instead:
# VITE_USE_MOCK_API=false
# VITE_API_BASE_URL=https://your-backend.onrender.com
# VITE_WS_URL=wss://your-backend.onrender.com/api/ws/live
